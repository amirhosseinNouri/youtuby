{
  "name": "youtuby",
  "version": "1.0.0",
  "description": "Telegram YouTube browser bot using a headless Chromium",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "bun src/index.ts",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "bot",
    "youtube",
    "playwright"
  ],
  "author": "Amirhossein Nouri",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "playwright": "^1.48.0",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
